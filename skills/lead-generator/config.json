{
  "apis": {
    "brave_search": {
      "api_key": "${BRAVE_SEARCH_API_KEY}",
      "base_url": "https://api.search.brave.com/res/v1",
      "rate_limit": 2000,
      "priority": 1
    },
    "tavily": {
      "api_key": "${TAVILY_API_KEY}",
      "base_url": "https://api.tavily.com",
      "rate_limit": 1000,
      "priority": 2,
      "fallback_for": "brave_search"
    },
    "hunter": {
      "api_key": "${HUNTER_API_KEY}",
      "base_url": "https://api.hunter.io/v2",
      "rate_limit": 500
    },
    "zyte": {
      "api_key": "${ZYTE_API_KEY}",
      "base_url": "https://api.zyte.com/v1",
      "rate_limit": 1000
    },
    "abstract": {
      "api_key": "${ABSTRACT_API_KEY}",
      "base_url": "https://companyenrichment.abstractapi.com/v1",
      "rate_limit": 500,
      "docs": "https://app.abstractapi.com/api/company-enrichment"
    }
  },
  "crawl4ai": {
    "enabled": true,
    "llm_provider": "zai",
    "llm_model": "glm-4.7",
    "api_key": "${CRAWL4AI_LLM_API_KEY}",
    "browser_config": {
      "headless": true,
      "page_timeout": 30000
    }
  },
  "web_access": {
    "enabled": true,
    "default_search": "brave_search",
    "fallback_enabled": true,
    "scraping_enabled": true
  }
}
