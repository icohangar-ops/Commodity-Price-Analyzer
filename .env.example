# =============================================================================
# Azure AI Foundry Configuration
# =============================================================================
AZURE_AI_ENDPOINT=https://<your-resource>.services.ai.azure.com/openai/v1
AZURE_AI_KEY=<YOUR_AZURE_AI_KEY>
AZURE_AI_DEPLOYMENT=Kimi-K2.6

# =============================================================================
# Microsoft Fabric Configuration
# =============================================================================
FABRIC_TENANT_ID=<YOUR_FABRIC_TENANT_ID>
FABRIC_WORKSPACE_ID=<YOUR_FABRIC_WORKSPACE_ID>
FABRIC_LAKEHOUSE_ID=<YOUR_LAKEHOUSE_ID>
FABRIC_CLIENT_ID=<YOUR_SERVICE_PRINCIPAL_CLIENT_ID>
FABRIC_CLIENT_SECRET=<YOUR_SERVICE_PRINCIPAL_CLIENT_SECRET>

# =============================================================================
# Commodity Data Sources
# =============================================================================
ALPHAVANTAGE_API_KEY=<YOUR_ALPHAVANTAGE_API_KEY>
REGULATIONS_GOV_API_KEY=<YOUR_REGULATIONS_GOV_API_KEY>

# =============================================================================
# Web Search & Lead-Generation APIs (skills/lead-generator)
# =============================================================================
BRAVE_SEARCH_API_KEY=<YOUR_BRAVE_SEARCH_API_KEY>
TAVILY_API_KEY=<YOUR_TAVILY_API_KEY>
HUNTER_API_KEY=<YOUR_HUNTER_API_KEY>
ZYTE_API_KEY=<YOUR_ZYTE_API_KEY>
ABSTRACT_API_KEY=<YOUR_ABSTRACT_API_KEY>
CRAWL4AI_LLM_API_KEY=<YOUR_CRAWL4AI_LLM_API_KEY>

# =============================================================================
# Email (himalaya-config.toml / test-email.sh)
# =============================================================================
GMAIL_APP_PASSWORD=<YOUR_GMAIL_APP_PASSWORD>
EMAIL_FROM=<YOUR_FROM_ADDRESS>
EMAIL_TO=<YOUR_TEST_RECIPIENT>

# =============================================================================
# Application Settings
# =============================================================================
LOG_LEVEL=INFO
DATA_REFRESH_INTERVAL_MINUTES=60
HISTORY_RETENTION_DAYS=365
